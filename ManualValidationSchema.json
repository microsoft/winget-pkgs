{
  "PR": {
	"Number": {
		"description": "The pull request number", 
		"type": [ "integer", "null" ],
		"minLength":5, 
		"maxLength":6, 
		"pattern": "[0-9]{5,6}",
	},
	"Title": {
		"description": "The pull request title", 
		"type": "string",
		"minLength":6, 
		"maxLength":128, 
		"pattern": "[a-zA-Z0-9]",
	},
  },
  "VM": {
	"Number": {
		"description": "The virtual machine number", 
		"type": "integer", 
		"minLength":4, 
		"maxLength":4, 
		"pattern": "[0-9]{4}",
    }
  },
  "CovertReview": {
	"IPv4": {
		"description": "IPv4 address", 
		"type": [ "string", "null" ],
		"minLength":7, 
		"pattern": "(((?!25?[6-9])[1]\\d|[1-9])?\\d\\.?\\b){4}",
    },
	"IPv6": {
		"description": "IPv6 address", 
		"type": [ "string", "null" ],
		"minLength":2, 
		"pattern": "(([0-9a-fA-F]{1,4}:){7,7}[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,7}:|([0-9a-fA-F]{1,4}:){1,6}:[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,5}(:[0-9a-fA-F]{1,4}){1,2}|([0-9a-fA-F]{1,4}:){1,4}(:[0-9a-fA-F]{1,4}){1,3}|([0-9a-fA-F]{1,4}:){1,3}(:[0-9a-fA-F]{1,4}){1,4}|([0-9a-fA-F]{1,4}:){1,2}(:[0-9a-fA-F]{1,4}){1,5}|[0-9a-fA-F]{1,4}:((:[0-9a-fA-F]{1,4}){1,6})|:((:[0-9a-fA-F]{1,4}){1,7}|:)|fe80:(:[0-9a-fA-F]{0,4}){0,4}%[0-9a-zA-Z]{1,}|::(ffff(:0{1,4}){0,1}:){0,1}((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\\.){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])|([0-9a-fA-F]{1,4}:){1,4}:((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\\.){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9]))",
    },
	"Transforms": {
		"description": "Transforms instalelr switch", 
		"type": [ "string", "null" ],
		"minLength":10, 
		"pattern": "TRANSFORMS",
    },
	"Patch": {
		"description": "Patch instalelr switch", 
		"type": [ "string", "null" ],
		"minLength": 5, 
		"pattern": "PATCH",
    },
	"Msp": {
		"description": "MSI Patch file extension", 
		"type": [ "string", "null" ],
		"minLength":3, 
		"pattern": "[.]msp",
    },
  },
  "General": {
  "WordFilterList": {
		"description": "List of words which block PR merging without an ApprovalUrl", 
		"type": [ "string", "null" ],
		"minLength": 4,
		"maxLength":38,
		"enum": [
			"accept_gdpr ",
			"accept-licenses",
			"accept-license",
			"eula",
			"downloadarchive.documentfoundation.org",
			"paypal"
		],
    },
  "SkipToContent": {
		"description": "First line of the GitHub manifest page", 
		"type": [ "string", "null" ],
		"minLength": 15,
		"maxLength":15,
		"enum": [
			"Skip to content"
		],
    },
  "manifests": {
		"description": "First word of the last half of a manifest file URL", 
		"type": [ "string", "null" ],
		"minLength": 16,
		"maxLength":1024,
		"pattern": "^manifests/",
    }
  }
}